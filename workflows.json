        "name": "Get Top Stories",
        "id": "98c18ca5-300d-4d5e-9f1a-601d3f961d1b"
      },
      {
        "parameters": {
          "jsCode": "return items.map(item => {\n  const top5 = item.json.results.slice(0,5).map((story, idx) => `${idx+1}. ${story.title} - ${story.url}`).join('\\n\\n');\n  return { json: { emailBody: `Top 5 NYTimes stories today:\\n\\n${top5}` } };\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          400,
          0
        ],
        "name": "Format Email Body",
        "id": "a7cd65e4-704f-46a8-b655-110130c64589"
      },
      {
        "parameters": {
          "fromEmail": "Nando.goat@gmail.com",
          "toEmail": "Nando.goat@gmail.com",
          "subject": "Today's Top 5 NYTimes Stories",
          "text": "={{ $json.emailBody }}",
          "options": {}
        },
        "type": "n8n-nodes-base.emailSend",
        "typeVersion": 2,
        "position": [
          608,
          0
        ],
        "name": "Send Email",
        "id": "b0702308-3196-4203-a2ba-cc7aeb307901",
        "webhookId": "78d3648c-41ae-493e-bff5-7a8886b06eef"
      }
    ],
    "connections": {
      "Daily Trigger": {
        "main": [
          [
            {
              "node": "Get Top Stories",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Get Top Stories": {
        "main": [
          [
