      },
      {
        "parameters": {
          "jsCode": "return items.map(item => {\n  const top5 = item.json.results.slice(0,5).map((story, idx) => `${idx+1}. ${story.title} - ${story.url}`).join('\\n\\n');\n  return { json: { emailBody: `Top 5 NYTimes stories today:\\n\\n${top5}` } };\n});"
