      },
      {
        "parameters": {
          "fromEmail": "Nando.goat@gmail.com",
          "toEmail": "Nando.goat@gmail.com",
          "subject": "Today's Top 5 NYTimes Stories",
          "text": "={{ $json.emailBody }}",
          "options": {}
        },
        "type": "n8n-nodes-base.emailSend",
