        "id": "472eeedd-c065-4045-a064-4fbe7169dca9",
        "name": "Input - User Query"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "http://host.docker.internal:7474/db/neo4j/tx/commit",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpBasicAuth",
          "sendBody": true,
          "contentType": "raw",
          "rawContentType": "application/json",
          "body": "={\n  \"statements\": [\n    {\n      \"statement\": \"CALL db.index.vector.queryNodes('documentEmbeddingIndex', $embedding) YIELD node, score RETURN node.title AS title, score\",\n      \"parameters\": {\n        \"embedding\": {{$json.embedding}}\n      }\n    }\n  ]\n}",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          784,
          0
        ],
        "id": "089c6a68-939a-43a8-967e-47792c5e8980",
        "name": "Request til Neo4j",
        "credentials": {
          "httpBasicAuth": {
            "id": "yJRR80som9xIIRfv",
            "name": "Unnamed credential 3"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const results = $json.results[0].data;\nreturn results.map(r => ({\n  json: { title: r.row[0], score: r.row[1] }\n}));"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          992,
          0
        ],
        "id": "20071149-6d2d-4a9a-970c-003aa9abd61c",
        "name": "Parse Node"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://api.openai.com/v1/embeddings",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpBearerAuth",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={\n  \"model\": \"text-embedding-3-small\",\n  \"input\": \"{{$json.query}}\"\n}",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.3,
        "position": [
          416,
          0
        ],
        "id": "a588de38-3504-49dc-b5f8-a2a5f14c4711",
        "name": "HTTP Request",
        "credentials": {
          "httpBearerAuth": {
            "id": "TEdrPFtecnuBGsVa",
            "name": "Bearer Auth account"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "return [{\n  json: {\n    query: $json.query,\n    embedding: $json.data[0].embedding\n  }\n}];"
