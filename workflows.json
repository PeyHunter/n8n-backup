    "active": false,
    "isArchived": false,
    "nodes": [
      {
        "parameters": {},
        "type": "n8n-nodes-base.manualTrigger",
        "typeVersion": 1,
        "position": [
          -384,
          -144
        ],
        "name": "Manual Trigger",
        "id": "02127cb9-e055-466e-92f6-62b1095d7ae4"
      },
      {
        "parameters": {
          "jsCode": "return [{ json: { id:'chunk1', text:'Retrieval Augmented Generation combines search and LLM generation.', source:'week7' } }, { json: { id:'chunk2', text:'Embeddings convert text into vectors so meaning can be compared mathematically.', source:'week7' } }, { json: { id:'chunk3', text:'Vector databases store embeddings and allow semantic similarity search.', source:'week7' } }];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -192,
          -144
        ],
        "name": "Sample Chunks",
        "id": "05a61eaf-2b71-4da0-bccb-93a1963b3e0d"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "https://api.openai.com/v1/embeddings",
          "authentication": "predefinedCredentialType",
          "nodeCredentialType": "openAiApi",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "model",
                "value": "text-embedding-3-small"
              },
              {
                "name": "input",
                "value": "=={{$json.text}}"
              }
            ]
          },
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [
          16,
          -144
        ],
        "name": "OpenAi Embedding",
        "id": "56ff353a-3b1c-4fee-95eb-525421a26da5",
        "credentials": {
          "openAiApi": {
            "id": "ixmI9i4jIDxysSAl",
            "name": "OpenAi account"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "return items.map((item,index)=>{const original=$items('Sample Chunks')[index].json;return { json:{ id:original.id, text:original.text, source:original.source, embedding:item.json.data[0].embedding } };});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          224,
          -144
        ],
        "name": "Merge Data",
        "id": "88cbc344-6dca-42d4-8300-c3b6d84188e2"
      },
      {
        "parameters": {
          "jsCode": "return items.map(item=>{const body={ statements:[ { statement:'MERGE (c:Chunk {id:$id}) SET c.text=$text, c.source=$source, c.embedding=$embedding', parameters:{ id:item.json.id, text:item.json.text, source:item.json.source, embedding:item.json.embedding } } ] }; return { json:{ neo4jBody:JSON.stringify(body) } };});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          416,
          -144
        ],
        "name": "Prepare Neo4j Body",
        "id": "de214cb7-8d5c-4604-ae6d-7788dba62989"
      },
      {
        "parameters": {
          "method": "POST",
          "url": "http://host.docker.internal:7474/db/neo4j/tx/commit",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpBasicAuth",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "sendBody": true,
          "contentType": "raw",
          "rawContentType": "application/json",
          "body": "={{$json.neo4jBody}}",
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [
          624,
          -144
        ],
        "name": "HTTP Request",
        "id": "ebf454e0-5339-4471-af54-beb92ef24453",
        "credentials": {
          "httpBasicAuth": {
            "id": "jqw56x8TsgswTJ25",
            "name": "Unnamed credential"
          }
        }
      }
    ],
