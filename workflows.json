          "body": "={\n  \"statements\": [\n    {\n      \"statement\": \"CALL db.index.fulltext.queryNodes('documentContentIndex', $query) YIELD node, score RETURN node.title AS title, score\",\n      \"parameters\": {\n        \"query\": \"{{$json.query}}\"\n      }\n    }\n  ]\n}",
